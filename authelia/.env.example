# authelia — copy to /srv/homelab/secrets/authelia.env on the Pi and
# fill in real values (RB-002). Generate each secret with:
#   openssl rand -hex 32
TZ=Europe/Berlin
AUTHELIA_SESSION_SECRET=changeme-openssl-rand-hex-32
AUTHELIA_STORAGE_ENCRYPTION_KEY=changeme-openssl-rand-hex-32
AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET=changeme-openssl-rand-hex-32
