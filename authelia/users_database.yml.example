---
# Copy to ${DATA_ROOT}/authelia/users_database.yml on the Pi (NOT in
# Git — it holds password hashes). Generate the hash with:
#
#   docker run --rm authelia/authelia:4.38.17 \
#     authelia crypto hash generate argon2 --password 'your-password'

users:
  marco:
    disabled: false
    displayname: Marco
    password: "$argon2id$v=19$m=65536,t=3,p=4$REPLACE_ME"
    email: marco@kirito.com
    groups:
      - admins
