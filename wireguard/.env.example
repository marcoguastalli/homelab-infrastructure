# wireguard — copy to /srv/homelab/secrets/wireguard.env on the Pi
# (RB-002).
TZ=Europe/Berlin
# Public endpoint clients connect to: your WAN IP or DDNS hostname
# (kirito.com is unregistered and will NOT work here — ADR-011 context).
WG_HOST=your-public-ip-or-ddns
# bcrypt hash for the wg-easy UI (defense in depth behind Authelia):
#   docker run --rm ghcr.io/wg-easy/wg-easy:14 wgpw 'your-password'
# Keep the single quotes wgpw prints; strip the PASSWORD_HASH= prefix.
PASSWORD_HASH=changeme-bcrypt-hash
